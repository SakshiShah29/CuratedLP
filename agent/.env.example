# ════════════════════════════════════════════════════════════
# CuratedLP Agent — Environment Variables
# Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════════

# ─── Phase 3: Chain + Contracts (REQUIRED) ──────────────────

# EOA private key for the curator (Alice / the LP).
# The MetaMask Smart Account is derived from this key.
CURATOR_PRIVATE_KEY=0x...

# EOA private key for the AI agent (Bob / Moltbot).
MOLTBOT_PRIVATE_KEY=0x...

# EOA private key for the volatility agent (Charlie — sub-delegation demo).
VOLATILITY_AGENT_PRIVATE_KEY=0x...

# Base Sepolia RPC endpoint (Alchemy/Infura — must support eth_sendRawTransaction).
# Pimlico bundler URL will NOT work here; that's PIMLICO_API_KEY below.
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Pimlico bundler API key (dashboard.pimlico.io → Base Sepolia).
PIMLICO_API_KEY=...

# Deployed contract addresses (fill after running Deploy.s.sol).
HOOK_ADDRESS=0xcD44d440b42320486f2BB63a4EfD21B7EB405AC0
ENFORCER_ADDRESS=0x...

# ERC-8004 identity NFT token ID owned by Curator Smart Account.
# Register by calling IdentityRegistry.register() from the Curator SA, then set this.
# IdentityRegistry on Base Sepolia: 0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_IDENTITY_ID=0

# Curator performance fee in basis points (max 2000 = 20%).
PERFORMANCE_FEE_BPS=1000

# ── Uniswap Trading API key (https://developers.uniswap.org/dashboard)
UNISWAP_API_KEY=...

# ── Uniswap data tool overrides (defaults to Base mainnet wstETH/USDC)
# UNISWAP_CHAIN_ID=8453
# WSTETH_ADDRESS=0xc1CBa3fCea344f92D9239c08C0568f6F2F0ee452
# USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── DexScreener network ID (defaults to "base")
# DEXSCREENER_NETWORK=base

# ── Venice AI API key (https://venice.ai/settings/api)
VENICE_API_KEY=...

# ── Venice model selection (defaults shown)
# VENICE_PRIMARY_MODEL=zai-org-glm-4.7
# VENICE_FALLBACK_MODEL=llama-3.3-70b
# CONFIDENCE_THRESHOLD=0.6

# ─── Phase 4: Locus — Agent Wallet (OPTIONAL) ───────────────
#
# Locus provides the agent's operational USDC wallet on Base mainnet.
# Used to pay for Olas Mech requests.
#
# Registration: POST https://beta-api.paywithlocus.com/api/register
#   { "name": "CuratedLP Curator", "email": "optional@example.com" }
# Returns: apiKey, ownerPrivateKey, walletId, ownerAddress
#
# Auth: direct Bearer token — the API key IS the Bearer token (no JWT exchange).
# Balance: GET /api/pay/balance with Authorization: Bearer claw_beta_...
#
# If not set, agent runs in MINIMAL mode (Olas skipped, free sources only).
LOCUS_API_KEY=claw_beta_...
LOCUS_WALLET_ID=

# Daily USDC spending limit for the agent (default: $5.00).
LOCUS_DAILY_LIMIT=5.0

# Per-transaction USDC limit (default: $0.50).
LOCUS_PER_TX_LIMIT=0.50

# ─── Phase 4: Olas Mech Marketplace (OPTIONAL) ──────────────
#
# Olas Mech Marketplace on Base mainnet for AI analysis requests.
# Requires: pip install mech-client  (Python >=3.10, <3.15)
#
# Discover mech address: mechx --client-mode mech list --chain-config base
# List tools for a mech: mechx --client-mode tool list <agent_id> --chain-config base
#
# If OLAS_MECH_ADDRESS is not set, agent auto-discovers at runtime.
# If not configured, agent skips Olas and logs warning.
OLAS_MECH_ADDRESS=0x...
OLAS_CHAIN_CONFIG=base

# Path to private key file for Olas payments.
# File must contain raw hex key with NO trailing newline (use: echo -n 0x... > key.txt)
# Defaults to ethereum_private_key.txt in working directory.
OLAS_PRIVATE_KEY_FILE=ethereum_private_key.txt

# Private key for signing Olas on-chain transactions.
# If not set, falls back to MOLTBOT_PRIVATE_KEY.
# Key is written to OLAS_PRIVATE_KEY_FILE at runtime (temp file, auto-deleted).
OLAS_PAYMENT_KEY=

# ─── Phase 4: EigenCompute TEE (Person B — OPTIONAL) ────────
#
# EigenCompute wraps the Venice AI inference in a TEE for verifiable computation.
# Set to "false" to use Venice directly without TEE wrapping.
# Defaults to true if Venice API key is set.
EIGENCOMPUTE_ENABLED=true
